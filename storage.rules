rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : null;
    }

    function isAdmin() {
      return signedIn() && userRole() == 'Administrador';
    }

    function hasAnyRole(roles) {
      return signedIn() && userRole() in roles;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /training-files/{sessionId}/{fileName} {
      allow read, create, update: if isAdmin() || hasAnyRole(['Analista', 'Formador']);
      allow delete: if isAdmin();
    }

    match /survey-files/{surveyId}/{fileName} {
      allow read, create, update: if isAdmin() || hasAnyRole(['Analista', 'Formador']);
      allow delete: if isAdmin();
    }

    match /report-files/{reportId}/{fileName} {
      allow read: if isAdmin() || hasAnyRole(['Analista', 'Coordinador', 'Sistemas']);
      allow create, update: if isAdmin() || hasAnyRole(['Analista']);
      allow delete: if isAdmin();
    }

    match /user-files/{uid}/{fileName} {
      allow read, create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if isAdmin();
    }
  }
}
